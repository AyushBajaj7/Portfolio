{
  "_comment": "TypeScript configuration for the main application source code",
  "compilerOptions": {
    /** Build info file location for incremental compilation */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    /** Target ECMAScript version - ES2023 for modern browser features */
    "target": "es2023",
    /** Library files to include - ES2023 and DOM APIs */
    "lib": ["ES2023", "DOM"],
    /** Module system - ESNext for modern module support */
    "module": "esnext",
    /** Type definitions - Vite client types for import.meta.env */
    "types": ["vite/client"],
    /** Skip type checking of declaration files for faster builds */
    "skipLibCheck": true,

    /* Bundler mode settings */
    /** Module resolution strategy for bundlers */
    "moduleResolution": "bundler",
    /** Allow importing TypeScript files with .ts/.tsx extensions */
    "allowImportingTsExtensions": true,
    /** Preserve import/export syntax for bundlers */
    "verbatimModuleSyntax": true,
    /** Force module detection for all files */
    "moduleDetection": "force",
    /** No emit - Vite handles compilation, not tsc */
    "noEmit": true,
    /** JSX transform mode - use react-jsx for automatic runtime */
    "jsx": "react-jsx",

    /* Linting options */
    /** Report errors on unused local variables */
    "noUnusedLocals": true,
    /** Report errors on unused parameters */
    "noUnusedParameters": true,
    /** Only allow syntax that can be erased (for compatibility) */
    "erasableSyntaxOnly": true,
    /** Report errors for fallthrough cases in switch statements */
    "noFallthroughCasesInSwitch": true
  },
  /** Source files to include in compilation */
  "include": ["src"]
}
